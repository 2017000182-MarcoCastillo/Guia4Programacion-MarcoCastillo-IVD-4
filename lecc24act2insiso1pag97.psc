Algoritmo sin_titulo
	Definir numero, i, multiplo Como Entero
	
    Escribir "Ingrese un número:"
    Leer numero
	
    Escribir "Los primeros 20 múltiplos de ", numero, " son:"
	
    Para i <- 1 Hasta 20 Hacer
        multiplo <- numero * i
        Escribir multiplo
    FinPara
FinAlgoritmo
